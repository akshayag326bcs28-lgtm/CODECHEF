#include <stdio.h>

int main() {
    int T;
    scanf("%d", &T);

    while (T--) {
        int X;
        char S[15];
        int carlsen = 0, chef = 0;

        scanf("%d", &X);
        scanf("%s", S);

        for (int i = 0; i < 14; i++) {
            if (S[i] == 'C')
                carlsen += 2;
            else if (S[i] == 'N')
                chef += 2;
            else {
                carlsen++;
                chef++;
            }
        }

        if (carlsen > chef)
            printf("%d\n", 60 * X);
        else if (carlsen == chef)
            printf("%d\n", 55 * X);
        else
            printf("%d\n", 40 * X);
    }

    return 0;
}
